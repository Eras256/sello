# Sumsub KYC Provider
SUMSUB_APP_TOKEN=your_sumsub_app_token
SUMSUB_SECRET_KEY=your_sumsub_secret_key
SUMSUB_WEBHOOK_SECRET=your_sumsub_webhook_secret

# Stellar / Soroban
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
STELLAR_SECRET_KEY=your_stellar_secret_key

# Contract Addresses (populated after deployment)
CONTRACT_ATTESTATION_STORE=CBFQHNPKRBBLZR4C34GJQ2DAOMABHJRARGP6SVZCPXTRIZQXTDLMVFOR
CONTRACT_TIER_REGISTRY=CDOGGHMW4TKO7IUVI3FVZ5IWTERSUJPQOBQP3SEHL3J2PA6IQUI6KL76

# Frontend (public)
NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_STELLAR_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_CONTRACT_ATTESTATION_STORE=CBFQHNPKRBBLZR4C34GJQ2DAOMABHJRARGP6SVZCPXTRIZQXTDLMVFOR
NEXT_PUBLIC_CONTRACT_TIER_REGISTRY=CDOGGHMW4TKO7IUVI3FVZ5IWTERSUJPQOBQP3SEHL3J2PA6IQUI6KL76

# API
API_PORT=3001
API_KEY=your_api_key_for_dev

# Environment
NODE_ENV=development

# ── MPP (Machine Payments Protocol) ──────────────────────────
# Required for paid API endpoints (/api/paid/*)
STELLAR_RECIPIENT=G...your_public_key...
MPP_SECRET_KEY=replace-with-strong-secret

# Optional: server pays Stellar network fees for clients
# FEE_PAYER_SECRET=S...your_secret_key...
