{
  "name": "sello",
  "version": "0.1.0",
  "private": true,
  "description": "SELLO — Compliance Infrastructure for Stellar. Verify once, access everything.",
  "license": "MIT",
  "scripts": {
    "dev": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api dev",
    "dev:sdk": "pnpm --filter @sello/sdk dev",
    "dev:all": "pnpm --parallel --filter web --filter api dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:contracts": "cd contracts && cargo test",
    "test:e2e": "pnpm --filter web test:e2e",
    "seed:testnet": "npx tsx scripts/seed-testnet.ts",
    "lint": "pnpm -r lint",
    "format": "pnpm -r format",
    "ship": "pnpm --filter @sello/sdk build && vercel --prod",
    "ship:preview": "pnpm --filter @sello/sdk build && vercel"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "devDependencies": {
    "next": "^16.2.4",
    "vercel": "^50.1.6"
  }
}
